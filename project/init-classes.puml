@startuml name "finta"

class Fact {
  - player: Player
  - time: string

  + Fact(player: Player, time: string)

  + getPlayer(): Player
  + getMinute(): string

  + setMinute(minute: string): void
  + setPlayer(player: Player): void
}

class Goal {
  - isOwnGoal: bool
  + Goal(player: Player, time: string, isOwnGoal: bool)
}

class YellowCard {
  + YellowCard(player: Player, time: string)
}

class RedCard {
  + RedCard(player: Player, time: string)
}

class Match {
  - id: unsigned long int
  - {static} nextId: unsigned long int
  - matchDay: unsigned short int
  - matchInfo: MatchInfo
  - matchResult: MatchResult

  + Match()
  + getId(): unsigned long int
  + getMatchDay(): unsigned short int
  + setMatchDay(matchDay: unsigned short int): void
  + getMatchInfo(): MatchInfo
  + setMatchInfo(matchInfo: MatchInfo): void
  + getMatchResult(): MatchResult
  + setMatchResult(matchResult: MatchResult): void
}

class MatchResult {
  - homeTeam: Team
  - awayTeam: Team
  - homeTeamScore: unsigned short int
  - awayTeamScore: unsigned short int

  + MatchResult(homeTeam: Team, awayTeam: Team, homeTeamScore: unsigned short int, awayTeamScore: unsigned short int)
  + getMatchResult(): string
  + setMatchResult(homeTeam: Team, awayTeam: Team, homeTeamScore: unsigned short int, awayTeamScore: unsigned short int): void
  + getHomeTeam(): Team
  + getAwayTeam(): Team
  + getAwayTeamScore(): unsigned short int
  + getHomeTeamScore(): unsigned short int
}

Class MatchInfo {
  - matchDate: Date
  - matchTime: Time
  - matchPlace: string
  - goals: Goal[]
  - yellowCards: Fact[]
  - redCards: Fact[]

  + MatchInfo(matchDate: Date, matchTime: Time, matchPlace: string)
  + getMatchDate(): Date
  + setMatchDate(matchDate: Date): void
  + getMatchHour(): Time
  + setMatchTime(matchTime: Time): void
  + getMatchPlace(): string
  + setMatchPlace(matchPlace: string): void
  + getGoals(): Goal[]
  + addGoal(goal: Goal): void
}

class Team {
  - name: string
  - points: unsigned short int
  - matchResults: MatchResult[]
  - staff: Person[]
  - players: Player[]
  - goals: unsigned short int
  - goalsAgainst: unsigned short int
  - goalsDifference: unsigned short int
  - yellowCards: unsigned short int
  - redCards: unsigned short int

  + Team(name: string)
  + getName(): string
  + setName(name: string): void
  + getPoints(): unsigned short int
  + addPoints(points: unsigned short int): void
  + getMatchResults(): MatchResult[]
  + addMatchResult(matchResult: MatchResult): void
  + getStaff(): Person[]
  + addStaff(person: Person): void
  + getPlayers(): Player[]
  + addPlayer(player: Player): void
}

class Person {
  - name: string

  + Person(name: string)
  + getName(): string
  + setName(name: string): void
}

class Player {
  - goalsScored: unsigned short int
  - yellowCards: unsigned short int
  - redCards: unsigned short int

  + Player(name: string, number: unsigned short int, position: string)
  + getGoalsScored(): unsigned short int
  + addGoalsScored(goalsScored: unsigned short int): void
  + getYellowCards(): unsigned short int
  + addYellowCards(yellowCards: unsigned short int): void
  + getRedCards(): unsigned short int
  + addRedCards(redCards: unsigned short int): void
}

class League {
  - name: string
  - teams: Team[]
  - matchResults: MatchResult[]

  + League(name: string)
  + League(name: string, teams: Team[])
  + League(name: string, teams: Team[], matchResults: MatchResult[])
 
  + getName(): string
  + setName(name: string): void
  + getTeams(): Team[]
  + addTeam(team: Team): void
  + getMatch(): Match
  + addMatch(match: Match): void
  + addMatch(matches: Match): void
  + findOrCreateTeam(const std::string& teamName)
  + fillMatchResults(string: filePath): void
}

class Console {
  - Console()

  + {static} printMatchResults(matchResults: MatchResult[]): void
  + {static} printMatchResult(team: Team): void
  + {static} printTable(teams: Team[]): void
}

MatchInfo "1" -- "goals 0..*" Goal
MatchInfo "1" -- "yellowCards 0..*" Fact
MatchInfo "1" -- "redCards 0..*" Fact

MatchResult "0..*" -- "homeTeam 1" Team
MatchResult "0..*" -- "1 awayTeam" Team
Team "0..*" -- "staff 1..*" Person
Team "0..*" -- "players 1..*" Player
League "0..*" -- "teams 20" Team
League "0..*" -- "matches 1..380" Match

Person <|-- Player
Fact <|-- Goal
Fact <|-- YellowCard
Fact <|-- RedCard

Match *-- MatchResult
Match *-- MatchInfo

MatchResult -- Console

@enduml
